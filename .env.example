# =============================================================================
# PureTask — environment template
# Copy: pnpm setup:env  →  edits .env.local
# Guide: docs/secrets-when-ready.md
# =============================================================================

# --- REQUIRED (app will not start without these) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Add later for payments / marketplace E2E ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_IDENTITY_WEBHOOK_SECRET=

# --- Add later for cleaner onboarding ---
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=
# 32-byte hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TAX_ENCRYPTION_KEY=

# --- Add later for scheduled jobs (Vercel cron) ---
CRON_SECRET=

# --- Optional (app degrades gracefully if unset) ---
GOOGLE_MAPS_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
