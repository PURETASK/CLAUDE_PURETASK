# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
.nyc_output/

# Next.js
/.next/
/out/

# Production
/build

# Misc
.DS_Store
Thumbs.db
*.swp
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env (keep template)
.env
.env.*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# Editor / OS
.idea/
.vscode/*
!.vscode/extensions.json

# Local MCP / AI tool config (machine-specific)
.mcp.json

# Claude Code / Cursor agent caches (per-machine)
.claude/
.agents/

# Supabase local (optional)
.branches/
.temp/
